generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Client {
  id            String   @id @default(uuid())
  name          String
  email         String
  phone         String
  problemType   String // Victim of Bank Fraud, Real Estate, etc.
  monetaryRange String // Less than $2.000.000, Between $2.000.000 and $4.000.000, More than $4.000.000
  caseDetails   String // Detailed description of the case
  urgent        Boolean  @default(false)
  createdAt     DateTime @default(now())
}
